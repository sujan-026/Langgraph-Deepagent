# .env file used by load_dotenv to insert environment variables in the jupter environment
# copy example.env to .env
# Required for research agents with external search
TAVILY_API_KEY=your_tavily_api_key_here

# Required for Bedrock model usage
AWS_REGION=ap-southeast-1
# Use the inference profile ID/ARN if your Bedrock model doesn't support on-demand invocation.
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
AWS_PROFILE=your-aws-sso-profile

# Optional override if you want a different lightweight summarizer model
BEDROCK_SUMMARIZER_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0

# TypeScript deep-agent runtime settings
DEEP_AGENT_STORAGE_DRIVER=sqlite
DEEP_AGENT_SQLITE_PATH=.deep-agent/threads.sqlite
DEEP_AGENT_MAX_ITERATIONS=8
DEEP_AGENT_MAX_SUBAGENT_DEPTH=1
DEEP_AGENT_MAX_PARALLEL_SUBAGENTS=2

# Local app URL used by the Next.js CopilotKit proxy route
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: For evaluation and tracing
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=deep-agents-from-scratch
